  "matraRules": [
    {
      "id": "rule-001",
      "ruleNumber": 1,
      "title": "स्वतंत्र स्वर (Independent Vowel)",
      "titleEnglish": "Independent Vowel",
      "description": "जेव्हा स्वर शब्दाच्या सुरुवातीला किंवा एकटा असतो तेव्हा तो स्वतंत्र रूप घेतो।",
      "descriptionEnglish": "When a vowel appears at the beginning of a word or stands alone, it takes its independent form.",
      "examples": [
        "𑀅 (अ)",
        "𑀆 (आ)",
        "𑀇 (इ)",
        "𑀈 (ई)"
      ],
      "examplesDevanagari": [
        "अ",
        "आ",
        "इ",
        "ई"
      ]
    },
    {
      "id": "rule-002",
      "ruleNumber": 2,
      "title": "मात्रा चिह्न (Matra Sign)",
      "titleEnglish": "Matra Sign",
      "description": "जेव्हा स्वर व्यंजनानंतर येतो तेव्हा तो मात्रा बनतो आणि व्यंजनाशी जोडलेला लिहिला जातो।",
      "descriptionEnglish": "When a vowel follows a consonant, it becomes a matra and is written attached to the consonant.",
      "examples": [
        "𑀓 + आ-matra = का",
        "𑀓𑀸 + = का"
      ],
      "examplesDevanagari": [
        "क + आ-मात्रा = का"
      ]
    },
    {
      "id": "rule-003",
      "ruleNumber": 3,
      "title": "मात्रेचे स्थान (Matra Position)",
      "titleEnglish": "Matra Position",
      "description": "मात्रा विविध ठिकाणी येतात: वर, खाली, व्यंजनाच्या आधी किंवा नंतर.",
      "descriptionEnglish": "Matras are placed in different positions: above, below, before, or after the consonant.",
      "examples": [
        "वर: कि (𑀓𑀹)",
        "खाली: कु (𑀓𑀻)",
        "मागे: का (𑀓𑀸)"
      ],
      "examplesDevanagari": [
        "वर: कि",
        "खाली: कु",
        "मागे: का"
      ]
    },
    {
      "id": "rule-004",
      "ruleNumber": 4,
      "title": "विशेष लक्ष्य (Special Note)",
      "titleEnglish": "Special Note",
      "description": "ब्राह्मी मधील मात्रांचा आकार आणि स्थान, देवनागरीपेक्षा थोडे वेगळे आहे। काळजीसह पाहा, ट्रेस करा आणि ओळखा।",
      "descriptionEnglish": "In Brahmi, the shape and position of matras differ slightly from Devanagari. Look carefully, trace, and practice recognizing them.",
      "examples": [],
      "examplesDevanagari": []
    }
  ],
