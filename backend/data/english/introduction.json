    {
      "id": "content-030",
      "lesson_id": "intro-encouragement",
      "content_type": "text",
      "title": "",
      "content": "Wow!",
      "metadata": {
        "buttonText": "Next"
      },
      "order_no": 1
    },
    {
      "id": "content-031",
      "lesson_id": "intro-encouragement",
      "content_type": "text",
      "title": "",
      "content": "This means that you can learn the entire Brahmi script in a very short time.",
      "metadata": {
        "buttonText": "Next"
      },
      "order_no": 2
    },
