          "8 मिनट",
          "10 मिनट",
          "15 मिनट"
        ],
        "buttonText": "अगला"
      },
      "order_no": 1
    },
    {
      "id": "content-030",
      "lesson_id": "intro-encouragement",
      "content_type": "text",
      "title": "",
      "content": "अरे वाह!",
      "metadata": {
        "buttonText": "अगला"
      },
      "order_no": 1
    },
    {
      "id": "content-031",
      "lesson_id": "intro-encouragement",
      "content_type": "text",
      "title": "",
      "content": "इसका अर्थ यह है कि आप बहुत कम समय में सम्पूर्ण ब्राह्मी लिपि सीख सकते हैं।",
      "metadata": {
        "buttonText": "अगला"
      },
      "order_no": 2
    },
    {
      "id": "content-032",
      "lesson_id": "intro-encouragement",
      "content_type": "title_slide",
      "title": "आइए! तो करते हैं",
      "content": "आरम्भ से प्रारम्भ।",
      "metadata": {
        "buttonText": "अगला"
      },
      "order_no": 3
    }
  ]
